{
  "ci": {
    "collect": {
      "staticDistDir": "./dist",
      "url": [
        "/",
        "/methodology",
        "/rules",
        "/incidents",
        "/audit",
        "/install",
        "/constitution",
        "/about",
        "/now",
        "/writing",
        "/rules/require-caller-in-tests",
        "/incidents/inc-001-git-stash-disaster",
        "/writing/2026-04-21-why-the-qa-harness-emits-over-stdio"
      ],
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop",
        "throttlingMethod": "simulate",
        "skipAudits": [
          "uses-rel-preconnect",
          "uses-rel-preload",
          "csp-xss",
          "is-on-https",
          "redirects-http",
          "uses-http2",
          "valid-source-maps"
        ]
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.95 }],
        "categories:accessibility": ["error", { "minScore": 0.95 }],
        "categories:best-practices": ["error", { "minScore": 0.95 }],
        "categories:seo": ["error", { "minScore": 0.95 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
