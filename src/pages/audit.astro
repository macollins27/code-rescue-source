---
import Page from '../layouts/Page.astro';
import { organization, person, service, breadcrumbs } from '../lib/jsonld.ts';

const url = 'https://code-rescue.com/audit';
const sampleUrl = '/docs/codex-audit-sample-report.pdf';
const bookMailto = 'mailto:max@code-rescue.com?subject=DRDD-A%20intro%20call';

const jsonLd = [
  organization(),
  person(),
  service({
    name: 'DRDD Audit',
    description:
      'A 30-to-43 page technical due-diligence audit. Read-only. Five business days. Source-first findings, full RAG matrix, remediation roadmap, partner-ready PDF.',
    serviceType: 'Technical Due Diligence',
    priceMin: 25000,
    priceMax: 40000,
    url,
  }),
  breadcrumbs([
    { name: 'Home', url: 'https://code-rescue.com/' },
    { name: 'Audit', url },
  ]),
];
---

<Page
  title="DRDD Audit — Code Rescue"
  description="A 30-to-43 page technical due-diligence audit, sourced from the codebase, defensible in committee. Five business days. Read-only access. $25-40K fixed."
  current="audit"
  page="/audit"
  jsonLd={jsonLd}
>
  {/* Hero */}
  <section style="padding: 44px 48px 32px; border-bottom: 1px solid var(--rule);">
    <div class="mono" style="font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-4); margin-bottom: 14px;">
      DRDD-A · fixed scope · read-only
    </div>
    <div style="display: grid; grid-template-columns: 1.4fr 1fr; gap: 56px; align-items: start;">
      <div>
        <h1 style="font-size: 34px; line-height: 1.18; letter-spacing: -0.02em; font-weight: 600; margin: 0; max-width: 24ch;">
          A 30-to-43 page technical due-diligence audit, sourced from the codebase, defensible in committee.
        </h1>
        <p class="serif" style="font-size: 17px; color: var(--ink-3); max-width: 58ch; margin-top: 18px; line-height: 1.55;">
          Five business days. Read-only access. No agents writing code. The deliverable is a partner-ready report with an overall RAG, a score per domain, a finding for every issue, and a remediation budget you can put in the model.
        </p>
        <div style="display: flex; gap: 22px; margin-top: 22px; font-size: 14px;">
          <a href={bookMailto}>Book a 30-min intro →</a>
          <a href={sampleUrl} style="color: var(--ink-2);">Sample audit (PDF)</a>
          <a href="/methodology" style="color: var(--ink-2);">Methodology paper</a>
        </div>
      </div>
      <table class="data" style="font-size: 13px;">
        <tbody>
          <tr><td style="color: var(--ink-4);">Price</td><td class="mono" style="text-align: right; color: var(--ink);">$25–40,000</td></tr>
          <tr><td style="color: var(--ink-4);">Calendar time</td><td class="mono" style="text-align: right; color: var(--ink);">5 business days</td></tr>
          <tr><td style="color: var(--ink-4);">Access required</td><td class="mono" style="text-align: right; color: var(--ink);">read-only repo</td></tr>
          <tr><td style="color: var(--ink-4);">Codebase ceiling</td><td class="mono" style="text-align: right; color: var(--ink);">~750k LOC</td></tr>
          <tr><td style="color: var(--ink-4);">Deliverable</td><td class="mono" style="text-align: right; color: var(--ink);">30–43 pp. PDF</td></tr>
          <tr><td style="color: var(--ink-4);">Scoring rubric</td><td class="mono" style="text-align: right; color: var(--ink);">DRDD v0.4</td></tr>
          <tr><td style="color: var(--ink-4);">NDA / SOC 2 lite</td><td class="mono" style="text-align: right; color: var(--ink);">standard</td></tr>
          <tr><td style="color: var(--ink-4);">Re-audit discount</td><td class="mono" style="text-align: right; color: var(--good);">40%</td></tr>
        </tbody>
      </table>
    </div>
  </section>

  {/* §1 Deliverable */}
  <section class="section tight">
    <div style="display: grid; grid-template-columns: 180px 1fr; gap: 32px; align-items: start;">
      <div>
        <div class="label">§1 Deliverable</div>
        <div style="font-size: 12px; color: var(--ink-4); font-family: var(--mono); margin-top: 8px;">What's in the PDF.</div>
      </div>
      <table class="data">
        <thead>
          <tr>
            <th style="width: 8%;">Pages</th>
            <th style="width: 22%;">Section</th>
            <th>Contents</th>
          </tr>
        </thead>
        <tbody>
          <tr><td class="mono">1</td><td>Cover</td><td>Overall RAG, score / 100, remediation estimate in $ and engineering hours, codebase size, primary stack, audit ID.</td></tr>
          <tr><td class="mono">2–3</td><td>Executive summary</td><td>One paragraph per domain. Plain-English deal implication. Investment recommendation with contingency reserve.</td></tr>
          <tr><td class="mono">3</td><td>RAG risk matrix</td><td>Six domains × severity counts (critical / high / medium / low / info). One table, no prose.</td></tr>
          <tr><td class="mono">4–7</td><td>Remediation roadmap</td><td>Every finding bucketed Immediate / 100-day / 6–12 month, with hours, $ estimate, and confidence band.</td></tr>
          <tr><td class="mono">8–37</td><td>Findings</td><td>Per finding: title, effort, confidence, evidence (file + line), impact, remediation. Cross-linked to <a href="/rules">rule corpus</a> where applicable.</td></tr>
          <tr><td class="mono">38–41</td><td>Domain deep-dives</td><td>Security, Team Health, Technical Debt, Dependencies, Scalability, Compliance — each with score derivation.</td></tr>
          <tr><td class="mono">42–43</td><td>Appendix</td><td>Methodology version, AI model and version pin, audit depth, reproducibility statement, what was <em>not</em> assessed.</td></tr>
        </tbody>
      </table>
    </div>
  </section>

  {/* §2 Boundaries */}
  <section class="section tight" style="background: var(--paper-2);">
    <div style="display: grid; grid-template-columns: 180px 1fr; gap: 32px; align-items: start;">
      <div>
        <div class="label">§2 Boundaries</div>
        <div style="font-size: 12px; color: var(--ink-4); font-family: var(--mono); margin-top: 8px;">What the audit is not.</div>
      </div>
      <table class="data" style="font-size: 14px;">
        <tbody>
          <tr><td class="mono" style="width: 8%; color: var(--ink-4);">01</td><td class="serif" style="font-size: 16px; color: var(--ink-2); line-height: 1.55;">Penetration testing or active exploitation.</td></tr>
          <tr><td class="mono" style="color: var(--ink-4);">02</td><td class="serif" style="font-size: 16px; color: var(--ink-2); line-height: 1.55;">Live infrastructure review (cloud config, DNS, IAM).</td></tr>
          <tr><td class="mono" style="color: var(--ink-4);">03</td><td class="serif" style="font-size: 16px; color: var(--ink-2); line-height: 1.55;">Legal opinion or formal regulatory filing.</td></tr>
          <tr><td class="mono" style="color: var(--ink-4);">04</td><td class="serif" style="font-size: 16px; color: var(--ink-2); line-height: 1.55;">Remediation work — that's <a href="/install">DRDD-I</a>.</td></tr>
          <tr><td class="mono" style="color: var(--ink-4);">05</td><td class="serif" style="font-size: 16px; color: var(--ink-2); line-height: 1.55;">Anything beyond the repos you grant access to.</td></tr>
        </tbody>
      </table>
    </div>
  </section>

  {/* §3 Cover, redacted */}
  <section class="section tight">
    <div class="label">§3 Cover, redacted</div>
    <div style="font-size: 12px; color: var(--ink-4); font-family: var(--mono); margin-bottom: 18px;">
      Page 1 of a real audit. Numbers verbatim, identifiers redacted. <a href={sampleUrl}>Full PDF →</a>
    </div>
    <div style="background: var(--paper); border: 1px solid var(--rule); padding: 36px; max-width: 720px; margin: 0 auto; box-shadow: 0 1px 0 var(--rule), 0 4px 20px rgba(0,0,0,0.04);">
      <div style="border-bottom: 1px solid var(--rule); padding-bottom: 10px; margin-bottom: 22px; font-size: 10px; font-family: var(--mono); color: var(--ink-4); display: flex; justify-content: space-between;">
        <span>CONFIDENTIAL — TECHNICAL DUE DILIGENCE</span>
        <span>Audit ID: ████ · 2026-03-06 · 1 / 43</span>
      </div>
      <div class="mono" style="font-size: 11px; color: var(--accent); letter-spacing: 0.18em; margin-bottom: 8px;">TECHNICAL DUE DILIGENCE</div>
      <h2 style="font-size: 28px; font-weight: 600; letter-spacing: -0.02em; margin: 0 0 28px;">Audit Report</h2>

      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 28px; padding: 20px 24px; background: var(--bad); color: #fff;">
        <div>
          <div style="font-size: 10px; opacity: 0.8; letter-spacing: 0.12em; text-transform: uppercase;">Overall risk</div>
          <div style="font-size: 36px; font-weight: 600; letter-spacing: -0.02em; margin-top: 4px;">RED</div>
        </div>
        <div>
          <div style="font-size: 10px; opacity: 0.8; letter-spacing: 0.12em; text-transform: uppercase;">Score</div>
          <div style="font-size: 36px; font-weight: 600; letter-spacing: -0.02em; margin-top: 4px; font-family: var(--mono);">73<span style="font-size: 18px; opacity: 0.7;"> / 100</span></div>
        </div>
      </div>

      <table class="data" style="font-size: 13px;">
        <tbody>
          <tr><td style="color: var(--ink-4); width: 44%;">Remediation estimate</td><td class="mono" style="text-align: right;">$1,240,000</td></tr>
          <tr><td style="color: var(--ink-4);">Engineering hours</td><td class="mono" style="text-align: right;">8,287 hrs</td></tr>
          <tr><td style="color: var(--ink-4);">Approximate FTE-years</td><td class="mono" style="text-align: right;">4.8</td></tr>
          <tr><td style="color: var(--ink-4);">Codebase size</td><td class="mono" style="text-align: right;">692,922 LOC</td></tr>
          <tr><td style="color: var(--ink-4);">Primary stack</td><td class="mono" style="text-align: right;">PHP / Laravel 8 + Vue.js 2</td></tr>
          <tr><td style="color: var(--ink-4);">AI model</td><td class="mono" style="text-align: right;">claude-sonnet-4-5-20250929</td></tr>
          <tr><td style="color: var(--ink-4);">Audit depth</td><td class="mono" style="text-align: right;">Standard</td></tr>
        </tbody>
      </table>
    </div>
  </section>

  {/* §4 RAG matrix */}
  <section class="section tight" style="background: var(--paper-2);">
    <div style="display: grid; grid-template-columns: 180px 1fr; gap: 32px; align-items: start;">
      <div>
        <div class="label">§4 RAG matrix</div>
        <div style="font-size: 12px; color: var(--ink-4); font-family: var(--mono); margin-top: 8px;">From the same report, page 3.</div>
      </div>
      <table class="data">
        <thead>
          <tr>
            <th style="width: 22%;">Domain</th>
            <th style="width: 8%;">RAG</th>
            <th style="width: 10%;">Score</th>
            <th style="width: 10%; text-align: right;">Critical</th>
            <th style="width: 10%; text-align: right;">High</th>
            <th style="width: 10%; text-align: right;">Medium</th>
            <th style="width: 10%; text-align: right;">Low</th>
            <th style="width: 10%; text-align: right;">Info</th>
          </tr>
        </thead>
        <tbody>
          {[
            { d: 'Security', s: '68/100', c: 1, h: 2, m: 1, l: 1, i: 0 },
            { d: 'Team Health', s: '62/100', c: 0, h: 3, m: 2, l: 1, i: 0 },
            { d: 'Technical Debt', s: '78/100', c: 1, h: 4, m: 0, l: 0, i: 0 },
            { d: 'Dependency Health', s: '71/100', c: 1, h: 2, m: 2, l: 1, i: 0 },
            { d: 'Scalability', s: '71/100', c: 1, h: 2, m: 2, l: 1, i: 0 },
            { d: 'Compliance', s: '86/100', c: 2, h: 3, m: 2, l: 0, i: 0 },
          ].map((row) => (
            <tr>
              <td>{row.d}</td>
              <td><span class="pill" style="background: var(--bad); color: #fff; border-color: var(--bad);">RED</span></td>
              <td class="mono">{row.s}</td>
              <td class="mono" style={`text-align: right; color: ${row.c ? 'var(--bad)' : 'var(--ink-4)'};`}>{row.c}</td>
              <td class="mono" style={`text-align: right; color: ${row.h ? 'var(--warn)' : 'var(--ink-4)'};`}>{row.h}</td>
              <td class="mono" style="text-align: right; color: var(--ink-3);">{row.m}</td>
              <td class="mono" style="text-align: right; color: var(--ink-4);">{row.l}</td>
              <td class="mono" style="text-align: right; color: var(--ink-4);">{row.i}</td>
            </tr>
          ))}
          <tr style="background: var(--paper-2);">
            <td style="font-weight: 600;">Total</td>
            <td></td>
            <td class="mono" style="font-weight: 600;">73/100</td>
            <td class="mono" style="text-align: right; font-weight: 600;">6</td>
            <td class="mono" style="text-align: right; font-weight: 600;">16</td>
            <td class="mono" style="text-align: right; font-weight: 600;">9</td>
            <td class="mono" style="text-align: right; font-weight: 600;">4</td>
            <td class="mono" style="text-align: right; font-weight: 600;">0</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  {/* §5 Remediation roadmap */}
  <section class="section tight">
    <div style="display: grid; grid-template-columns: 180px 1fr; gap: 32px; align-items: start;">
      <div>
        <div class="label">§5 Remediation roadmap</div>
        <div style="font-size: 12px; color: var(--ink-4); font-family: var(--mono); margin-top: 8px;">Bucketed by tier. Hours shown with confidence band.</div>
      </div>
      <div>
        <table class="data" style="margin-bottom: 24px;">
          <thead>
            <tr>
              <th style="width: 26%;">Priority tier</th>
              <th style="width: 12%; text-align: right;">Items</th>
              <th style="width: 20%; text-align: right;">Hours</th>
              <th style="text-align: right;">Estimated cost</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><span class="dot crit"></span>Immediate</td>
              <td class="mono" style="text-align: right;">8</td>
              <td class="mono" style="text-align: right;">1,048</td>
              <td class="mono" style="text-align: right;">$157,200</td>
            </tr>
            <tr>
              <td><span class="dot high"></span>100-day plan</td>
              <td class="mono" style="text-align: right;">23</td>
              <td class="mono" style="text-align: right;">5,222</td>
              <td class="mono" style="text-align: right;">$783,300</td>
            </tr>
            <tr>
              <td><span class="dot med"></span>6–12 month</td>
              <td class="mono" style="text-align: right;">4</td>
              <td class="mono" style="text-align: right;">161</td>
              <td class="mono" style="text-align: right;">$24,150</td>
            </tr>
            <tr style="border-top: 2px solid var(--ink);">
              <td style="font-weight: 600;">Total</td>
              <td class="mono" style="text-align: right; font-weight: 600;">35</td>
              <td class="mono" style="text-align: right; font-weight: 600;">8,287</td>
              <td class="mono" style="text-align: right; font-weight: 600;">$1,240,000 – $1,964,650</td>
            </tr>
          </tbody>
        </table>
        <div class="serif" style="font-size: 14px; color: var(--ink-3); line-height: 1.55; max-width: 70ch;">
          The wide upper bound is <em>not</em> padding — it accounts for team-health risk surfacing during execution. Where the audit finds a Red on Team Health, the report flags which remediation lines are likely to overrun and by how much.
        </div>
      </div>
    </div>
  </section>

  {/* §6 Finding format */}
  <section class="section tight" style="background: var(--paper-2);">
    <div style="display: grid; grid-template-columns: 180px 1fr; gap: 32px; align-items: start;">
      <div>
        <div class="label">§6 Finding format</div>
        <div style="font-size: 12px; color: var(--ink-4); font-family: var(--mono); margin-top: 8px;">One specimen. Every finding follows this shape.</div>
      </div>
      <div style="border: 1px solid var(--rule); background: var(--paper);">
        <div style="padding: 14px 20px; border-bottom: 1px solid var(--rule); display: flex; justify-content: space-between; align-items: center; font-family: var(--mono); font-size: 11px; color: var(--ink-4);">
          <span>SEC-001 · Immediate · Security</span>
          <span><span class="dot crit"></span>CRITICAL</span>
        </div>
        <div style="padding: 20px 24px;">
          <div style="font-size: 17px; font-weight: 600; letter-spacing: -0.01em; margin-bottom: 12px;">
            Master Password Backdoor Allows Unrestricted Account Access
          </div>
          <table class="data" style="font-size: 13px; margin-bottom: 16px;">
            <tbody>
              <tr>
                <td style="color: var(--ink-4); width: 20%;">Effort</td>
                <td class="mono">40 hrs</td>
                <td style="color: var(--ink-4); width: 20%;">Confidence</td>
                <td class="mono" style="color: var(--good);">high</td>
              </tr>
              <tr>
                <td style="color: var(--ink-4);">Evidence</td>
                <td class="mono" colspan="3">app/Http/Controllers/Auth/LoginController.php:127–148</td>
              </tr>
              <tr>
                <td style="color: var(--ink-4);">Frameworks impacted</td>
                <td colspan="3">GDPR · CCPA · SOC 2</td>
              </tr>
              <tr>
                <td style="color: var(--ink-4);">Locked rule</td>
                <td colspan="3"><span style="font-family: var(--mono);">no-master-bypass</span> · added to the client repo at post-close integration (every install authors its own client-specific rules from origin incidents)</td>
              </tr>
            </tbody>
          </table>
          <div class="serif" style="font-size: 15px; color: var(--ink-2); line-height: 1.6;">
            <p style="margin: 0 0 0.8em;"><strong>Impact.</strong> An attacker who discovers the master password can impersonate any user, including administrators, accessing all sensitive data and performing financial transactions. Creates severe legal liability and regulatory violations.</p>
            <p style="margin: 0;"><strong>Remediation.</strong> Remove the bypass. Audit the access log for the past 24 months for any use of the credential. Add the locked rule above to CI on day one of post-close integration.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* §7 The five days */}
  <section class="section tight">
    <div style="display: grid; grid-template-columns: 180px 1fr; gap: 32px; align-items: start;">
      <div>
        <div class="label">§7 The five days</div>
        <div style="font-size: 12px; color: var(--ink-4); font-family: var(--mono); margin-top: 8px;">What happens, and what you do.</div>
      </div>
      <table class="data">
        <thead>
          <tr>
            <th style="width: 10%;">Day</th>
            <th style="width: 30%;">Phase</th>
            <th>What happens</th>
            <th style="width: 18%; text-align: right;">You do</th>
          </tr>
        </thead>
        <tbody>
          <tr><td class="mono">D-3</td><td>NDA, repo access, scope lock</td><td>Standard NDA. Read-only deploy key. Stack and module list. Anything you want me to ignore.</td><td class="mono" style="text-align: right;">~30 min</td></tr>
          <tr><td class="mono">1</td><td>Topology + scoring frame</td><td>Whole-repo read. Domain weighting set against your industry and stage. Initial RAG hypothesis.</td><td class="mono" style="text-align: right; color: var(--ink-4);">—</td></tr>
          <tr><td class="mono">2</td><td>Source-first findings pass</td><td>Every finding lands with a file + line. AST-grep + hookify rule corpus run as a first sweep.</td><td class="mono" style="text-align: right; color: var(--ink-4);">—</td></tr>
          <tr><td class="mono">3</td><td>Adversarial review</td><td>Nine-pass review per domain. Findings either survive with stronger evidence or get cut.</td><td class="mono" style="text-align: right; color: var(--ink-4);">—</td></tr>
          <tr><td class="mono">4</td><td>Remediation costing</td><td>Hours per finding × confidence. Bucketed Immediate / 100-day / 6–12 month with cost band.</td><td class="mono" style="text-align: right;">~45 min Q&amp;A</td></tr>
          <tr><td class="mono">5</td><td>Report + walkthrough</td><td>Final PDF. 60-min walkthrough with your deal team. One round of Q&amp;A by email afterward.</td><td class="mono" style="text-align: right;">60 min</td></tr>
        </tbody>
      </table>
    </div>
  </section>

  {/* §8 Commitments */}
  <section class="section tight" style="background: var(--paper-2);">
    <div style="display: grid; grid-template-columns: 180px 1fr; gap: 32px; align-items: start;">
      <div>
        <div class="label">§8 Commitments</div>
        <div style="font-size: 12px; color: var(--ink-4); font-family: var(--mono); margin-top: 8px;">What I will tell you, in writing.</div>
      </div>
      <div class="serif" style="font-size: 16px; line-height: 1.65; color: var(--ink-2);">
        <p style="margin: 0 0 0.9em;"><strong style="color: var(--ink);">Where my confidence is low, and why.</strong> Spelled out per finding.</p>
        <p style="margin: 0 0 0.9em;"><strong style="color: var(--ink);">Which findings depend on assumptions about traffic or data volume.</strong> The assumption named.</p>
        <p style="margin: 0 0 0.9em;"><strong style="color: var(--ink);">Which line items are likely to overrun if Team Health is Red.</strong> Where the team probably can't absorb the work.</p>
        <p style="margin: 0 0 0.9em;"><strong style="color: var(--ink);">Which findings are blockers for your specific exit thesis.</strong> Not generic risk.</p>
        <p style="margin: 0;"><strong style="color: var(--ink);">What I would not buy this company for.</strong> In writing, in the report.</p>
      </div>
    </div>
  </section>

  {/* §9 Next */}
  <section class="section tight" style="border-bottom: none;">
    <div style="display: grid; grid-template-columns: 180px 1fr; gap: 32px; align-items: start;">
      <div>
        <div class="label">§9 Next</div>
      </div>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 32px;">
        <div style="border-top: 2px solid var(--ink); padding-top: 14px;">
          <div style="font-size: 17px; font-weight: 600; margin-bottom: 6px;">Book a 30-minute intro</div>
          <div class="serif" style="font-size: 14px; color: var(--ink-3); line-height: 1.55; margin-bottom: 14px;">
            Tell me the company, the stack, and the deadline. I'll tell you whether DRDD-A is the right shape for the diligence and quote a band before we hang up.
          </div>
          <a href={bookMailto}>max@code-rescue.com →</a>
        </div>
        <div style="border-top: 2px solid var(--rule-2); padding-top: 14px;">
          <div style="font-size: 17px; font-weight: 600; margin-bottom: 6px;">Read the artifact first</div>
          <div class="serif" style="font-size: 14px; color: var(--ink-3); line-height: 1.55; margin-bottom: 14px;">
            Most buyers want the sample audit and the methodology paper before any call. Both are public. Skim them, then book if the shape fits.
          </div>
          <div style="display: flex; gap: 18px; font-size: 14px;">
            <a href={sampleUrl}>Sample audit (PDF) →</a>
            <a href="/methodology">Methodology paper →</a>
          </div>
