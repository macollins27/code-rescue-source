---
import { getCollection } from 'astro:content';
import Page from '../../layouts/Page.astro';
import { organization, person, website, breadcrumbs } from '../../lib/jsonld.ts';

const all = (await getCollection('writing'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => (a.data.date < b.data.date ? 1 : -1));

const url = 'https://code-rescue.com/writing';

const jsonLd = [
  organization(),
  person(),
  website(),
  {
    '@context': 'https://schema.org',
    '@type': 'Blog',
    url,
    name: 'Code Rescue — Writing',
    description: 'Notes on AI-augmented engineering, failure analysis, and the discipline of locking rules.',
    publisher: { '@id': 'https://code-rescue.com/#organization' },
    author: { '@id': 'https://code-rescue.com/#max' },
    blogPost: all.map((p) => ({
      '@type': 'BlogPosting',
      headline: p.data.title,
      url: `${url}/${p.id}`,
      datePublished: p.data.date,
    })),
  },
  breadcrumbs([
    { name: 'Home', url: 'https://code-rescue.com/' },
    { name: 'Writing', url },
  ]),
];
---

<Page
  title="Writing — Code Rescue"
  description="Long-form notes on AI-augmented engineering, failure analysis, and the discipline of locking rules."
  current="writing"
  page="/writing"
  jsonLd={jsonLd}
>
  {/* Hero */}
  <section style="padding: 44px 48px 32px; border-bottom: 1px solid var(--rule);">
    <div class="mono" style="font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-4); margin-bottom: 14px;">
      Writing · {all.length} {all.length === 1 ? 'post' : 'posts'}
    </div>
    <div style="display: grid; grid-template-columns: 1.4fr 1fr; gap: 56px; align-items: end;">
      <div>
        <h1 style="font-size: 44px; line-height: 1.1; letter-spacing: -0.02em; font-weight: 600; margin: 0; max-width: 22ch;">
          Notes from the inside of the methodology.
        </h1>
        <p class="serif" style="font-size: 17.5px; color: var(--ink-2); max-width: 60ch; margin-top: 22px; line-height: 1.55;">
          Failure analysis, methodology decisions, and the recurring problem of getting agents to comply with prose specifications under context decay. Updated when an incident produces a writeup, or a methodology choice is worth defending in long-form.
        </p>
      </div>
      <div style="display: flex; flex-direction: column; gap: 8px; font-size: 13px;">
        <a href="/rss.xml" class="mono" style="color: var(--ink-3); border-bottom: 1px solid var(--rule);">RSS feed →</a>
      </div>
    </div>
  </section>

  {/* Index list */}
  <section class="section tight">
    <ul style="list-style: none; padding: 0; margin: 0;">
      {all.map((p) => (
        <li style="border-bottom: 1px solid var(--rule); padding: 18px 0; display: grid; grid-template-columns: 120px 1fr; gap: 20px; align-items: baseline;">
          <span class="mono" style="font-size: 12px; color: var(--ink-4);">{p.data.date}</span>
          <div>
            <a href={`/writing/${p.id}`} style="color: var(--ink); border-bottom: none; font-size: 18px; font-weight: 500; letter-spacing: -0.01em;">{p.data.title}</a>
            <div class="serif" style="font-size: 14.5px; color: var(--ink-3); line-height: 1.55; margin-top: 6px; max-width: 64ch;">
              {p.data.description}
            </div>
            {p.data.tags.length > 0 && (
              <div style="margin-top: 8px; display: flex; gap: 8px; flex-wrap: wrap;">
                {p.data.tags.map((t) => (
                  <span class="mono" style="font-size: 11px; color: var(--ink-4);">#{t}</span>
                ))}
              </div>
            )}
          </div>
        </li>
      ))}
    </ul>
    {all.length === 0 && (
      <p class="serif" style="font-size: 16px; color: var(--ink-3); padding: 32px 0;">
        No posts yet. Drafts in flight.
      </p>
    )}
  </section>
</Page>
