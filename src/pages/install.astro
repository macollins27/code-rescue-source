---
import Page from '../layouts/Page.astro';
import { organization, person, service, breadcrumbs } from '../lib/jsonld.ts';

const url = 'https://code-rescue.com/install';
const bookMailto = 'mailto:max@code-rescue.com?subject=DRDD-I%20intro%20call';

const jsonLd = [
  organization(),
  person(),
  service({
    name: 'DRDD Install',
    description:
      'The methodology installed in your repo. Constitution, gates, hooks, ast-grep + hookify rule packs, QA harness, dispatch protocol, agent-review hooks. Six to eight weeks. Locked, version-pinned.',
    serviceType: 'AI-augmented engineering install',
    priceMin: 80000,
    priceMax: 150000,
    url,
  }),
  breadcrumbs([
    { name: 'Home', url: 'https://code-rescue.com/' },
    { name: 'Install', url },
  ]),
];
---

<Page
  title="DRDD Install — Code Rescue"
  description="The methodology, installed in your repo, with locked rules and a QA harness that runs in your CI. Six to eight weeks. $80-150K fixed scope."
  current="install"
  page="/install"
  ogImage="/og/install.png"
  jsonLd={jsonLd}
>
  {/* Hero */}
  <section style="padding: 44px 48px 32px; border-bottom: 1px solid var(--rule);">
    <div class="mono" style="font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-4); margin-bottom: 14px;">
      DRDD-I · fixed scope · build engagement
    </div>
    <div style="display: grid; grid-template-columns: 1.4fr 1fr; gap: 56px; align-items: start;">
      <div>
        <h1 style="font-size: 34px; line-height: 1.18; letter-spacing: -0.02em; font-weight: 600; margin: 0; max-width: 26ch;">
          The methodology, installed in your repo, with locked rules and a QA harness that runs in your CI.
        </h1>
        <p class="serif" style="font-size: 17px; color: var(--ink-3); max-width: 60ch; margin-top: 18px; line-height: 1.55;">
          Six to eight weeks. The output is committed code in your repo: a constitution, gates, hooks, an ast-grep + hookify rule pack tuned to your stack, a Playwright-driven QA harness, a dispatch protocol, and agent-review hooks. Locked, version-pinned, with origin incidents documented.
        </p>
        <div style="display: flex; gap: 22px; margin-top: 22px; font-size: 14px;">
          <a href={bookMailto}>Book a 30-min intro →</a>
          <a href="#deliverables" style="color: var(--ink-2);">What gets committed (list)</a>
          <a href="/methodology" style="color: var(--ink-2);">Methodology paper</a>
        </div>
      </div>
      <table class="data" style="font-size: 13px;">
        <tbody>
          <tr><td style="color: var(--ink-4);">Price</td><td class="mono" style="text-align: right; color: var(--ink);">$80–150,000</td></tr>
          <tr><td style="color: var(--ink-4);">Calendar time</td><td class="mono" style="text-align: right; color: var(--ink);">42–56 days</td></tr>
          <tr><td style="color: var(--ink-4);">Engagement model</td><td class="mono" style="text-align: right; color: var(--ink);">solo, fixed scope</td></tr>
          <tr><td style="color: var(--ink-4);">Access required</td><td class="mono" style="text-align: right; color: var(--ink);">write, scoped</td></tr>
          <tr><td style="color: var(--ink-4);">Stack ceiling</td><td class="mono" style="text-align: right; color: var(--ink);">3 primary languages</td></tr>
          <tr><td style="color: var(--ink-4);">Deliverable</td><td class="mono" style="text-align: right; color: var(--ink);">committed PR set</td></tr>
          <tr><td style="color: var(--ink-4);">Rule pack base</td><td class="mono" style="text-align: right; color: var(--ink);">89 rules + custom</td></tr>
          <tr><td style="color: var(--ink-4);">30-day support</td><td class="mono" style="text-align: right; color: var(--good);">included</td></tr>
        </tbody>
      </table>
    </div>
  </section>

  {/* §1 Why install */}
  <section class="section tight">
    <div style="display: grid; grid-template-columns: 180px 1fr; gap: 32px; align-items: start;">
      <div>
        <div class="label">§1 Why install</div>
        <div style="font-size: 12px; color: var(--ink-4); font-family: var(--mono); margin-top: 8px;">The case in three lines.</div>
      </div>
      <div class="serif" style="font-size: 16px; line-height: 1.65; color: var(--ink-2); max-width: 72ch;">
        <p style="margin: 0 0 0.9em;"><strong style="color: var(--ink);">An audit tells you what's wrong.</strong> It doesn't change what your team will do tomorrow. The findings sit in a PDF.</p>
        <p style="margin: 0 0 0.9em;"><strong style="color: var(--ink);">An install changes the tomorrows.</strong> Rules become commits. Gates become CI checks. The constitution becomes the document every agent reads at session start. The next time someone — human or model — tries to make the same mistake, the build fails before review.</p>
        <p style="margin: 0;"><strong style="color: var(--ink);">Both, sometimes.</strong> Diligence buyers usually start with <a href="/audit">DRDD-A</a>. Operators with a team still building usually go straight to install. If you bought a company and got a Red, you probably want both — the audit credit applies to install.</p>
      </div>
    </div>
  </section>

  {/* §2 Deliverables */}
  <section id="deliverables" class="section tight" style="background: var(--paper-2);">
    <div style="display: grid; grid-template-columns: 180px 1fr; gap: 32px; align-items: start;">
      <div>
        <div class="label">§2 Deliverables</div>
        <div style="font-size: 12px; color: var(--ink-4); font-family: var(--mono); margin-top: 8px;">What lands in your repo.</div>
      </div>
      <table class="data">
        <thead>
          <tr>
            <th style="width: 20%;">Path</th>
            <th style="width: 16%;">Artifact</th>
            <th>What it does</th>
            <th style="width: 12%; text-align: right;">Form</th>
          </tr>
        </thead>
        <tbody>
          <tr><td class="mono" style="color: var(--accent);"><a href="/constitution" style="color: var(--accent); border-bottom: none;">.drdd/constitution.md</a></td><td>Constitution</td><td>Eight non-negotiable principles. Read at every agent session start. Cited from every locked rule and gate by ID. <a href="/constitution">View the public version</a>.</td><td class="mono" style="text-align: right;">markdown</td></tr>
          <tr><td class="mono" style="color: var(--accent);">.drdd/rules/ast-grep/</td><td>ast-grep rule pack</td><td>41 base rules + custom. Static patterns that fail the build on match. Origin incident documented per rule.</td><td class="mono" style="text-align: right;">YAML</td></tr>
          <tr><td class="mono" style="color: var(--accent);">.drdd/rules/hookify/</td><td>hookify rule pack</td><td>48 base rules + custom. Hookable patterns that run on file save, pre-commit, or post-agent-edit.</td><td class="mono" style="text-align: right;">markdown</td></tr>
          <tr><td class="mono" style="color: var(--accent);">.drdd/gates/</td><td>CI gates</td><td>Lint / type / test / rules / harness, in that order. Each gate fails fast and cites the rule it tripped on.</td><td class="mono" style="text-align: right;">shell + YAML</td></tr>
          <tr><td class="mono" style="color: var(--accent);">.drdd/hooks/</td><td>Agent-review hooks</td><td>PreToolUse and PostToolUse hooks. Block git stash, force review on three-subagent disagreement, etc.</td><td class="mono" style="text-align: right;">shell</td></tr>
          <tr><td class="mono" style="color: var(--accent);">scripts/qa-flows/</td><td>QA harness</td><td>66 base flows + custom. Real Chromium via Playwright MCP. Emits over stdio. Findings survive back-pressure.</td><td class="mono" style="text-align: right;">YAML</td></tr>
          <tr><td class="mono" style="color: var(--accent);">.drdd/skills/</td><td>Dispatch skills</td><td>Frontend-implement, schema-migrate, audit-readout, etc. One shape. Lock protocol enforced.</td><td class="mono" style="text-align: right;">markdown</td></tr>
          <tr><td class="mono" style="color: var(--accent);">.drdd/incidents/</td><td>Incident catalog</td><td>Open log. Each entry: date, session id, root cause, locked rule. Wired to your retrospectives.</td><td class="mono" style="text-align: right;">markdown</td></tr>
          <tr><td class="mono" style="color: var(--accent);">docs/runbook.md</td><td>Runbook</td><td>How to add a rule, how to lock it, how to roll one back. The document your senior engineer reads in week six and never asks me a question about.</td><td class="mono" style="text-align: right;">markdown</td></tr>
        </tbody>
      </table>
    </div>
  </section>

  {/* §3 Specimen rule */}
  <section class="section tight">
    <div style="display: grid; grid-template-columns: 180px 1fr; gap: 32px; align-items: start;">
      <div>
        <div class="label">§3 Specimen rule</div>
        <div style="font-size: 12px; color: var(--ink-4); font-family: var(--mono); margin-top: 8px;">One hookify rule, with its origin.</div>
      </div>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px;">
        <div style="border: 1px solid var(--rule); background: var(--paper);">
          <div style="padding: 12px 18px; border-bottom: 1px solid var(--rule); font-family: var(--mono); font-size: 11px; color: var(--ink-4); display: flex; justify-content: space-between;">
            <span><a href="/rules/block-dangerous-git" style="color: var(--ink-4); border-bottom: none;">block-dangerous-git</a></span>
            <span style="color: var(--good);">locked 2026-03-20</span>
          </div>
          <pre class="code" style="border: none; margin: 0;">{`---
name: block-dangerous-git
enabled: true
event: bash
tool_matcher: Bash
action: block
conditions:
  - field: command
    operator: regex_match
    pattern: (git\\s+stash|git\\s+reset\\s+--hard|git\\s+clean\\s+-[fFxXd]|git\\s+rebase|git\\s+restore|git\\s+worktree\\s+add|git\\s+filter-branch|git\\s+filter-repo|git\\s+push\\s+(--force|-f)\\b|git\\s+branch\\s+(-D|-d)\\s|git\\s+push\\s+origin\\s+--delete|rm\\s+-rf\\s+\\.git)
---

🚫 GIT GUARD — Destructive git command blocked.

Past incident: an agent ran git stash + worktree add → 20+ commits dropped, 2 days of manual transcript recovery.

Blocked: git stash · reset --hard · clean -fd · rebase · restore · worktree add · filter-branch · push --force · branch -D · push origin --delete · rm -rf .git

Trunk-based development. All work to main. No branches, no worktrees, no stashes.

origin:
  incident: INC-001
  date: 2026-03-20
  cost: 20+ commits lost, ~20 hours of work, ~4 hrs recovery`}</pre>
        </div>
        <div style="border: 1px solid var(--rule); background: var(--paper);">
          <div style="padding: 12px 18px; border-bottom: 1px solid var(--rule); font-family: var(--mono); font-size: 11px; color: var(--ink-4);">
            Origin · <a href="/incidents/inc-001-git-stash-disaster" style="color: var(--ink-3); border-bottom: none;">INC‑001 · 2026‑03‑20</a>
          </div>
          <div style="padding: 16px 20px;">
            <div class="serif" style="font-size: 14.5px; line-height: 1.6; color: var(--ink-2);">
              <p style="margin: 0 0 0.8em;"><strong>What happened.</strong> A rogue agent ran <code class="mono" style="font-size: 13px;">git stash</code> repeatedly across a worktree and created a worktree at <code class="mono" style="font-size: 13px;">.claude/worktrees/agent-a62d2c03</code>. The stashed work was never returned to. A recovery agent then ran <code class="mono" style="font-size: 13px;">rm -rf .git &amp;&amp; cp -r recovery-clone/.git .git</code>, wiping 20+ local-only commits.</p>
              <p style="margin: 0 0 0.8em;"><strong>Cost.</strong> 20+ commits lost. ~20 hours of work destroyed. ~4 hours of forensic recovery.</p>
              <p style="margin: 0;"><strong>Lock.</strong> The <a href="/rules/block-dangerous-git">block-dangerous-git</a> hookify rule at the keystroke, the <code class="mono" style="font-size: 13px;">git-guard.sh</code> bash hook at PreToolUse, and the <code class="mono" style="font-size: 13px;">permissions.deny</code> list in <code class="mono" style="font-size: 13px;">settings.json</code> — sixteen destructive patterns, three enforcement layers. Full incident at <a href="/incidents/inc-001-git-stash-disaster">INC‑001</a>; writeup at <a href="/writing/2026-03-22-twenty-commits-one-git-stash">Twenty commits, one git stash, no warning</a>.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* §4 The six weeks */}
  <section class="section tight" style="background: var(--paper-2);">
    <div style="display: grid; grid-template-columns: 180px 1fr; gap: 32px; align-items: start;">
      <div>
        <div class="label">§4 The six weeks</div>
        <div style="font-size: 12px; color: var(--ink-4); font-family: var(--mono); margin-top: 8px;">What ships when.</div>
      </div>
      <table class="data">
        <thead>
          <tr>
            <th style="width: 10%;">Week</th>
            <th style="width: 26%;">Phase</th>
            <th>What ships, in PRs</th>
            <th style="width: 16%; text-align: right;">You do</th>
          </tr>
        </thead>
        <tbody>
          <tr><td class="mono">W-1</td><td>Scoping audit</td><td>Read-only sweep against the DRDD rubric. Output is a 10–15 pp. RAG memo sized to the install. Scope locked from this.</td><td class="mono" style="text-align: right;">~2 hrs</td></tr>
          <tr><td class="mono">1</td><td>Constitution + gates</td><td>PR #1: <code class="mono" style="font-size: 13px;">.drdd/</code> scaffold, constitution drafted with your VPE, lint/type/test gates wired into CI.</td><td class="mono" style="text-align: right;">~3 hrs review</td></tr>
          <tr><td class="mono">2</td><td>Base rule pack</td><td>PR #2: 89 base rules tuned to your stack and removed where they don't fit. Each rule's origin documented or marked <em>borrowed</em>.</td><td class="mono" style="text-align: right;">~2 hrs review</td></tr>
          <tr><td class="mono">3</td><td>Custom rules from your incidents</td><td>PR #3: 8–20 custom rules derived from your last six months of postmortems and bug bashes. Each one with the incident as origin.</td><td class="mono" style="text-align: right;">~4 hrs interviews</td></tr>
          <tr><td class="mono">4</td><td>QA harness</td><td>PR #4: scripts/qa-flows/ with 8–15 flows covering your top user journeys. Real Chromium. Findings flow into the same rule-violation surface.</td><td class="mono" style="text-align: right;">~3 hrs review</td></tr>
          <tr><td class="mono">5</td><td>Agent hooks + dispatch</td><td>PR #5: PreToolUse / PostToolUse hooks, dispatch protocol, agent-review hooks. Three-subagent disagreement triggers escalation.</td><td class="mono" style="text-align: right;">~3 hrs pairing</td></tr>
          <tr><td class="mono">6</td><td>Lock + handoff</td><td>PR #6: runbook, version pin, incident catalog scaffold, lock procedure. 90-minute walkthrough with your senior engineers. They can add and lock rules without me.</td><td class="mono" style="text-align: right;">90 min walkthrough</td></tr>
          <tr><td class="mono">+30d</td><td>Support window</td><td>30 calendar days. Rule-authoring help, gate tuning, and one round of changes. Anything beyond that is a follow-up engagement.</td><td class="mono" style="text-align: right;">email</td></tr>
        </tbody>
      </table>
    </div>
  </section>

  {/* §5 Commitments */}
  <section class="section tight">
    <div style="display: grid; grid-template-columns: 180px 1fr; gap: 32px; align-items: start;">
      <div>
        <div class="label">§5 Commitments</div>
        <div style="font-size: 12px; color: var(--ink-4); font-family: var(--mono); margin-top: 8px;">What I commit to, in writing.</div>
      </div>
      <div class="serif" style="font-size: 16px; line-height: 1.65; color: var(--ink-2);">
        <p style="margin: 0 0 0.9em;"><strong style="color: var(--ink);">Every rule has an origin.</strong> Either from your last six months of postmortems, or marked <em>borrowed</em>. No "we just thought it was a good idea."</p>
        <p style="margin: 0 0 0.9em;"><strong style="color: var(--ink);">Every gate runs in under 8 minutes</strong> on a clean cache. If yours exceeds, I tune it before lock.</p>
        <p style="margin: 0 0 0.9em;"><strong style="color: var(--ink);">The runbook is sufficient.</strong> Your senior engineer adds and locks rules without me. The 30-day window is for tuning, not for learning to use the toolkit.</p>
        <p style="margin: 0 0 0.9em;"><strong style="color: var(--ink);">If a rule causes false positives over 5%, I rewrite it before lock.</strong> No "we'll tighten it later."</p>
        <p style="margin: 0;"><strong style="color: var(--ink);">If you'd unwind it after 30 days, I refund the lock-week fee.</strong></p>
      </div>
    </div>
  </section>

  {/* §6 Pricing band */}
  <section class="section tight" style="background: var(--paper-2);">
    <div style="display: grid; grid-template-columns: 180px 1fr; gap: 32px; align-items: start;">
      <div>
        <div class="label">§6 Pricing band</div>
        <div style="font-size: 12px; color: var(--ink-4); font-family: var(--mono); margin-top: 8px;">What pushes you to the high end.</div>
      </div>
      <table class="data">
        <thead>
          <tr>
            <th style="width: 26%;">Factor</th>
            <th style="width: 12%;">Floor</th>
            <th style="width: 12%;">Ceiling</th>
            <th>What it changes</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>Codebase size</td><td class="mono">≤150k LOC</td><td class="mono">≤750k LOC</td><td>Drives sweep time in W-1 and the size of the custom-rule pass in W-3.</td></tr>
          <tr><td>Primary languages</td><td class="mono">1</td><td class="mono">3</td><td>ast-grep rules are language-specific. Each additional primary language adds ~5 days.</td></tr>
          <tr><td>Existing CI maturity</td><td>Modern</td><td>None</td><td>If you already have a coherent pipeline, gates plug in. If not, half of W-1 is laying CI.</td></tr>
          <tr><td>Postmortem history</td><td>Documented</td><td>Tribal</td><td>Custom rules need origin incidents. If yours live in heads, W-3 grows.</td></tr>
          <tr><td>Team size at handoff</td><td class="mono">≤8 eng</td><td class="mono">≤30 eng</td><td>Drives the depth of the runbook and the W-6 walkthrough format.</td></tr>
          <tr style="border-top: 2px solid var(--ink);">
            <td style="font-weight: 600;">Engagement total</td>
            <td class="mono" style="font-weight: 600;">$80,000</td>
            <td class="mono" style="font-weight: 600;">$150,000</td>
            <td class="serif" style="color: var(--ink-3);">Quoted as a band before contract; settled before W-1.</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  {/* §7 Worked example */}
  <section class="section tight">
    <div style="display: grid; grid-template-columns: 180px 1fr; gap: 32px; align-items: start;">
      <div>
        <div class="label">§7 Worked example</div>
        <div style="font-size: 12px; color: var(--ink-4); font-family: var(--mono); margin-top: 8px;">How a real codebase stacks.</div>
      </div>
      <div>
        <p class="serif" style="font-size: 16px; color: var(--ink-2); line-height: 1.6; max-width: 62ch; margin-top: 0; margin-bottom: 18px;">
          The engagement that produced this site's <a href="/rules">rule corpus</a> and <a href="/incidents">incident catalog</a> is a clean specimen of the bands. Here's how its shape stacks.
        </p>
        <table class="data" style="font-size: 13px;">
          <thead>
            <tr>
              <th style="width: 26%;">Factor</th>
              <th style="width: 30%;">This codebase</th>
              <th>Where that lands</th>
            </tr>
          </thead>
          <tbody>
            <tr><td>Codebase size</td><td class="mono">~225K LOC TS/TSX</td><td>Mid sweep range</td></tr>
            <tr><td>Primary languages</td><td class="mono">1 (TypeScript)</td><td>At the floor</td></tr>
            <tr><td>Existing CI maturity</td><td>None at engagement start</td><td>Ceiling — half of W-1 was laying CI</td></tr>
            <tr><td>Postmortem history</td><td>Tribal at engagement start</td><td>Ceiling — the 9 incidents at <a href="/incidents">/incidents</a> were locked during W-3 origin pass</td></tr>
            <tr><td>Team size at handoff</td><td class="mono">1 eng (solo build)</td><td>At the floor</td></tr>
            <tr style="border-top: 2px solid var(--ink);">
              <td style="font-weight: 600;">Lands at</td>
              <td class="mono" style="font-weight: 600;">$120,000</td>
              <td class="serif" style="color: var(--ink-3);">Mid-sized codebase + zero starting infrastructure cancels low language count and small team.</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  {/* §8 Boundaries */}
  <section class="section tight" style="background: var(--paper-2);">
    <div style="display: grid; grid-template-columns: 180px 1fr; gap: 32px; align-items: start;">
      <div>
        <div class="label">§8 Boundaries</div>
        <div style="font-size: 12px; color: var(--ink-4); font-family: var(--mono); margin-top: 8px;">What the install is not.</div>
      </div>
      <div>
        <div style="font-size: 13px; font-weight: 600; color: var(--ink-2); margin-bottom: 10px;">Not included</div>
        <table class="data" style="font-size: 14px;">
          <tbody>
            <tr><td class="mono" style="width: 8%; color: var(--ink-4);">01</td><td class="serif" style="font-size: 16px; color: var(--ink-2); line-height: 1.55;">Feature work or product engineering.</td></tr>
            <tr><td class="mono" style="color: var(--ink-4);">02</td><td class="serif" style="font-size: 16px; color: var(--ink-2); line-height: 1.55;">Refactors of existing code (rules guard going forward).</td></tr>
            <tr><td class="mono" style="color: var(--ink-4);">03</td><td class="serif" style="font-size: 16px; color: var(--ink-2); line-height: 1.55;">Hiring, eng leadership, or org-design advisory.</td></tr>
            <tr><td class="mono" style="color: var(--ink-4);">04</td><td class="serif" style="font-size: 16px; color: var(--ink-2); line-height: 1.55;">Security pen-testing or compliance certification.</td></tr>
            <tr><td class="mono" style="color: var(--ink-4);">05</td><td class="serif" style="font-size: 16px; color: var(--ink-2); line-height: 1.55;">Operating your CI past the 30-day window.</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  {/* §9 Next */}
  <section class="section tight" style="border-bottom: none;">
    <div style="display: grid; grid-template-columns: 180px 1fr; gap: 32px; align-items: start;">
      <div>
        <div class="label">§9 Next</div>
      </div>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 32px;">
        <div style="border-top: 2px solid var(--ink); padding-top: 14px;">
          <div style="font-size: 17px; font-weight: 600; margin-bottom: 6px;">Book a 30-minute intro</div>
          <div class="serif" style="font-size: 14px; color: var(--ink-3); line-height: 1.55; margin-bottom: 14px;">
            Tell me the stack, the team size, and what your last bad outage was. I'll quote a band and a window before we hang up.
          </div>
          <a href={bookMailto}>max@code-rescue.com →</a>
        </div>
        <div style="border-top: 2px solid var(--rule-2); padding-top: 14px;">
          <div style="font-size: 17px; font-weight: 600; margin-bottom: 6px;">Read the corpus first</div>
          <div class="serif" style="font-size: 14px; color: var(--ink-3); line-height: 1.55; margin-bottom: 14px;">
            The 89 base rules are public. If they look like the kind of thing your team should already be enforcing, an install is probably the right shape.
          </div>
