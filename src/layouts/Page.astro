---
import Base from './Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  current?: string;
  page?: string;
  updated?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description,
  current,
  page = Astro.url.pathname,
  updated,
  ogImage,
  ogType,
  jsonLd,
} = Astro.props;
---

<Base title={title} description={description} ogImage={ogImage} ogType={ogType} jsonLd={jsonLd}>
  <Nav current={current} />
  <slot />
  <Footer page={page} updated={updated} />
</Base>
