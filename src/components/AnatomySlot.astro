---
interface Props {
  label: string;
}

const { label } = Astro.props;
---

<div style="margin-bottom: 16px;">
  <div class="mono" style="font-size: 10.5px; color: var(--ink-4); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 6px;">{label}</div>
  <div class="serif" style="font-size: 15px; line-height: 1.6; color: var(--ink-2);">
    <slot />
  </div>
</div>
