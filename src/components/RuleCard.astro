---
export interface Rule {
  n: string;
  title: string;
  tagline: string;
  body: string;
  counter: string;
  litmus: string;
}

interface Props {
  rule: Rule;
}

const { rule } = Astro.props;
---

<article style="border-top: 1px solid var(--rule-2); padding-top: 28px; padding-bottom: 28px;">
  <div style="display: grid; grid-template-columns: 120px 1fr; gap: 32px; align-items: start;">
    <div>
      <div class="mono" style="font-size: 11px; color: var(--accent); letter-spacing: 0.12em;">{rule.n}</div>
    </div>
    <div>
      <h3 style="font-size: 22px; font-weight: 600; letter-spacing: -0.015em; margin: 0 0 6px; color: var(--ink);">
        {rule.title}
      </h3>
      <div class="serif" style="font-size: 16px; font-style: italic; color: var(--ink-3); margin-bottom: 18px;">
        {rule.tagline}
      </div>
      <div class="serif" style="font-size: 16px; line-height: 1.65; color: var(--ink-2); margin-bottom: 18px;" set:html={rule.body}></div>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-top: 22px;">
        <div style="border-left: 2px solid var(--rule-2); padding-left: 14px;">
          <div class="mono" style="font-size: 10.5px; color: var(--ink-4); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 6px;">Counter-example</div>
          <div class="serif" style="font-size: 14.5px; font-style: italic; color: var(--ink-3); line-height: 1.55;" set:html={rule.counter}></div>
        </div>
        <div style="border-left: 2px solid var(--accent); padding-left: 14px;">
          <div class="mono" style="font-size: 10.5px; color: var(--accent); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 6px;">Litmus test</div>
          <div class="serif" style="font-size: 14.5px; font-style: italic; color: var(--ink-2); line-height: 1.55;" set:html={rule.litmus}></div>
        </div>
      </div>
    </div>
  </div>
</article>
