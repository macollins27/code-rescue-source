---
import SeverityDot from './SeverityDot.astro';
import PillTone from './PillTone.astro';

interface Incident {
  displayId: string;
  date: string;
  session?: string;
  severity: 'crit' | 'high' | 'med';
  title: string;
  caughtBy: string;
  cost?: string;
  what?: string;
  how?: string;
  ruleKind?: string;
  ruleDisplayId: string;
  ruleSeverity?: string;
  ruleLockedOn?: string;
  ruleGloss?: string;
  ruleYaml?: string;
  ruleCites: string[];
}

interface Props {
  incident: Incident;
}

const { incident } = Astro.props;

function dayDelta(a: string, b: string): string {
  const da = new Date(a + 'T00:00:00Z').getTime();
  const db = new Date(b + 'T00:00:00Z').getTime();
  const days = Math.round((db - da) / (1000 * 60 * 60 * 24));
  return days === 1 ? '1 day' : `${days} days`;
}

const sameDay = incident.ruleLockedOn === incident.date;
---

<article style="border-top: 1px solid var(--rule); padding: 44px 0;">
  {/* Header */}
  <header style="display: grid; grid-template-columns: 180px 1fr; gap: 32px; margin-bottom: 36px;">
    <div>
      <div class="mono" style="font-size: 11px; color: var(--ink-4); letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 10px;">Incident</div>
      <div style="display: flex; align-items: baseline; gap: 10px; flex-wrap: wrap;">
        <span style="font-size: 20px; font-weight: 600; font-family: var(--mono); color: var(--accent);">{incident.displayId}</span>
        <SeverityDot severity={incident.severity} />
        <span class="mono" style="font-size: 11.5px; color: var(--ink-4); text-transform: uppercase; letter-spacing: 0.06em;">{incident.severity}</span>
      </div>
      <div class="mono" style="font-size: 12px; color: var(--ink-4); margin-top: 8px;">
        {incident.date}{incident.session ? ` · session ${incident.session}` : ''}
      </div>
    </div>
    <div>
      <h2 style="font-size: 28px; font-weight: 600; margin: 0; letter-spacing: -0.015em; line-height: 1.18; max-width: 32ch;">{incident.title}</h2>
      <div style="margin-top: 14px; display: flex; gap: 28px; flex-wrap: wrap; font-size: 12.5px;">
        <div>
          <span class="mono" style="color: var(--ink-4); letter-spacing: 0.06em; text-transform: uppercase; font-size: 10.5px; margin-right: 8px;">Caught by</span>
          <span class="mono" style="color: var(--ink-2);">{incident.caughtBy}</span>
        </div>
        {incident.cost && (
          <div>
            <span class="mono" style="color: var(--ink-4); letter-spacing: 0.06em; text-transform: uppercase; font-size: 10.5px; margin-right: 8px;">Cost</span>
            <span class="mono" style="color: var(--ink-2);">{incident.cost}</span>
          </div>
        )}
      </div>
    </div>
  </header>

  {/* Beats */}
  <div style="display: grid; grid-template-columns: 180px 1fr; gap: 32px;">
    <div style="position: relative;">
      <div style="position: sticky; top: 24px;">
        <div class="mono" style="font-size: 10.5px; color: var(--ink-4); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 10px;">The moment</div>
        <div style="font-size: 12px; color: var(--ink-4); font-family: var(--mono); line-height: 1.5;">
          Three beats. The third is what permanently blocks it.
        </div>
      </div>
    </div>

    <div>
      {/* Beat 1 */}
      <div style="padding-bottom: 28px; border-bottom: 1px solid var(--rule-2);">
        <div style="display: flex; align-items: baseline; gap: 14px;">
          <span class="mono" style="font-size: 11px; color: var(--ink-4); letter-spacing: 0.12em; text-transform: uppercase; font-weight: 600;">Beat 1</span>
          <span style="font-size: 17px; font-weight: 600; letter-spacing: -0.01em;">What happened</span>
        </div>
        <div class="serif" style="font-size: 16px; color: var(--ink-2); line-height: 1.65; margin-top: 12px; max-width: 62ch;" set:html={incident.what ?? ''}></div>
      </div>

      {/* Beat 2 */}
      <div style="padding: 28px 0; border-bottom: 1px solid var(--rule-2);">
        <div style="display: flex; align-items: baseline; gap: 14px;">
          <span class="mono" style="font-size: 11px; color: var(--ink-4); letter-spacing: 0.12em; text-transform: uppercase; font-weight: 600;">Beat 2</span>
          <span style="font-size: 17px; font-weight: 600; letter-spacing: -0.01em;">How we caught it</span>
          <span class="mono" style="font-size: 11.5px; color: var(--ink-4);">{incident.caughtBy}</span>
        </div>
        <div class="serif" style="font-size: 16px; color: var(--ink-2); line-height: 1.65; margin-top: 12px; max-width: 62ch;" set:html={incident.how ?? ''}></div>
      </div>

      {/* Beat 3 — the reveal */}
      <div style="padding-top: 28px; position: relative;">
        <div style="display: flex; align-items: baseline; gap: 14px;">
          <span class="mono" style="font-size: 11px; color: var(--ink-4); letter-spacing: 0.12em; text-transform: uppercase; font-weight: 600;">Beat 3</span>
          <span style="font-size: 17px; font-weight: 600; letter-spacing: -0.01em;">What now blocks it</span>
          {incident.ruleLockedOn && (
            <span class="mono" style="font-size: 11.5px; color: var(--ink-4);">locked {incident.ruleLockedOn}</span>
          )}
        </div>

        <div style="margin-top: 18px; position: relative;">
          <div style="position: absolute; left: -24px; top: 0; bottom: 0; width: 3px; background: var(--accent);"></div>

          <div style="border: 1px solid var(--rule); background: var(--paper-2);">
            <div style="padding: 16px 22px; border-bottom: 1px solid var(--rule); display: flex; align-items: baseline; justify-content: space-between; gap: 16px; flex-wrap: wrap;">
              <div style="display: flex; align-items: baseline; gap: 12px; flex-wrap: wrap;">
                <span class="mono" style="font-size: 10.5px; color: var(--ink-4); letter-spacing: 0.08em; text-transform: uppercase;">{incident.ruleKind}</span>
                <span style="font-size: 17px; font-weight: 600; font-family: var(--mono); color: var(--accent);">{incident.ruleDisplayId}</span>
                {incident.ruleSeverity && <PillTone tone={incident.ruleSeverity}>{incident.ruleSeverity}</PillTone>}
              </div>
              {incident.ruleLockedOn && (
                <span class="mono" style="font-size: 11.5px; color: var(--ink-4);">locked {incident.ruleLockedOn}</span>
              )}
            </div>
            {incident.ruleGloss && (
              <div class="serif" style="font-size: 14.5px; color: var(--ink-2); line-height: 1.55; padding: 16px 22px 14px;">
                {incident.ruleGloss}
              </div>
            )}
            {incident.ruleYaml && (
              <pre class="code" style="font-size: 11.5px; padding: 0 22px 18px; margin: 0; line-height: 1.55; background: transparent; border: none;">{incident.ruleYaml}</pre>
            )}
            <div style="border-top: 1px solid var(--rule); padding: 12px 22px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 12px;">
              <div class="mono" style="font-size: 11.5px; color: var(--ink-4);">
                {incident.ruleCites.length > 0 && (
                  <>
                    Cites:
                    {' '}
                    {incident.ruleCites.map((c, i) => (
                      <>
                        {i > 0 && <span style="color: var(--ink-4);"> · </span>}
                        <span class="mono" style="color: var(--accent); font-size: 11.5px;">{c}</span>
                      </>
                    ))}
                  </>
                )}
              </div>
              <a href="/rules" class="mono" style="font-size: 11.5px; color: var(--ink-3); border-bottom: 1px solid var(--rule);">full corpus → /rules</a>
            </div>
          </div>

          {/* Coda */}
          {incident.ruleLockedOn && (
            <div class="mono" style="font-size: 11.5px; color: var(--ink-3); margin-top: 14px; line-height: 1.5;">
              {sameDay ? (
                <>Failure → rule, <span style="color: var(--good);">same day</span>. Every incident on this page produced one.</>
              ) : (
                <>Locked {dayDelta(incident.date, incident.ruleLockedOn)} after the incident. Every incident on this page produced a rule.</>
              )}
            </div>
          )}
        </div>
      </div>
    </div>
  </div>
</article>
